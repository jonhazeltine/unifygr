---
// StudioDock — the floating, staff-only AI editor that rides along on the real
// site. It sits quietly in the corner; staff sign in once and it stays open as
// they navigate, always knowing which page they're on. Invisible (and inert)
// to normal visitors: it only reveals itself after a valid passcode, and every
// backend route it calls requires the staff cookie anyway.
//
// Included once before </body> on every page (via Interior.astro + index.astro).
// Pages stay static; this checks the session client-side and reveals on demand.
---

<div id="sd-root" class="sd-root" data-state="hidden" aria-live="polite">
	<!-- Launcher pill -->
	<button id="sd-launch" class="sd-launch" type="button" aria-label="Open the site editor">
		<span class="sd-spark">✦</span> Edit
	</button>

	<!-- Panel -->
	<section id="sd-panel" class="sd-panel" role="dialog" aria-label="Site editor">
		<header class="sd-head">
			<div class="sd-head__title">
				<span class="sd-spark">✦</span>
				<div>
					<strong>Studio</strong>
					<span id="sd-page" class="sd-page">this page</span>
				</div>
			</div>
			<div class="sd-head__actions">
				<button id="sd-undo" class="sd-icon" type="button" title="Undo last change" aria-label="Undo last change" hidden>↺</button>
				<button id="sd-signout" class="sd-icon" type="button" title="Sign out" hidden>⎋</button>
				<button id="sd-close" class="sd-icon" type="button" title="Close" aria-label="Close">×</button>
			</div>
		</header>

		<!-- Sign-in view -->
		<div id="sd-signin" class="sd-signin" hidden>
			<p>Staff editor. Enter the passcode to make changes to the site.</p>
			<form id="sd-signin-form">
				<input id="sd-pass" type="password" placeholder="Passcode" autocomplete="off" />
				<button type="submit">Enter</button>
			</form>
			<p id="sd-signin-err" class="sd-err"></p>
		</div>

		<!-- Chat view -->
		<div id="sd-chat" class="sd-chat" hidden>
			<div id="sd-log" class="sd-log"></div>
			<div id="sd-proposal"></div>
			<form id="sd-composer" class="sd-composer">
				<input id="sd-msg" type="text" placeholder="Tell me what to change…" autocomplete="off" />
				<button type="submit" id="sd-send" aria-label="Send">→</button>
			</form>
		</div>
	</section>
</div>

<style>
	.sd-root { position: fixed; right: 20px; bottom: 20px; z-index: 2147483000; font-family: inherit; }
	.sd-root[data-state="hidden"] { display: none; }
	/* [hidden] must win over the display rules below (UA rule loses on specificity). */
	.sd-panel [hidden] { display: none !important; }
	.sd-spark { color: var(--gold, #f2d2a2); }

	.sd-launch {
		display: inline-flex; align-items: center; gap: 7px;
		padding: 11px 18px; border-radius: 999px; cursor: pointer;
		font: 600 14px/1 inherit; letter-spacing: .01em;
		color: #12100c; border: 1px solid rgba(242,210,162,.5);
		background: linear-gradient(135deg, #ffe7bf, #f2d2a2);
		box-shadow: 0 14px 40px rgba(0,0,0,.45);
		transition: transform .18s ease, box-shadow .18s ease;
	}
	.sd-launch:hover { transform: translateY(-2px); box-shadow: 0 18px 46px rgba(0,0,0,.55); }
	.sd-root[data-state="open"] .sd-launch,
	.sd-root[data-state="signin"] .sd-launch { display: none; }

	.sd-panel {
		display: none; flex-direction: column;
		width: min(390px, calc(100vw - 32px)); height: min(560px, calc(100vh - 40px));
		border-radius: 18px; overflow: hidden;
		background: rgba(10, 13, 18, 0.86);
		-webkit-backdrop-filter: blur(18px); backdrop-filter: blur(18px);
		border: 1px solid var(--line, rgba(255,255,255,.14));
		box-shadow: 0 40px 120px rgba(0,0,0,.6);
		color: var(--text, #f6f0e7);
	}
	.sd-root[data-state="open"] .sd-panel,
	.sd-root[data-state="signin"] .sd-panel { display: flex; animation: sd-rise .22s ease; }
	@keyframes sd-rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

	.sd-head { display: flex; align-items: center; justify-content: space-between; padding: 13px 14px; border-bottom: 1px solid var(--line, rgba(255,255,255,.12)); }
	.sd-head__title { display: flex; align-items: center; gap: 9px; }
	.sd-head__title strong { display: block; font-size: 14px; letter-spacing: .02em; }
	.sd-page { display: block; font-size: 11px; color: var(--muted, rgba(246,240,231,.7)); text-transform: capitalize; }
	.sd-head__actions { display: flex; gap: 4px; }
	.sd-icon { background: transparent; border: 0; color: var(--muted, rgba(246,240,231,.7)); font-size: 18px; width: 30px; height: 30px; border-radius: 8px; cursor: pointer; line-height: 1; }
	.sd-icon:hover { background: rgba(255,255,255,.08); color: var(--text, #f6f0e7); }

	.sd-signin { padding: 22px 16px; }
	.sd-signin p { margin: 0 0 14px; font-size: 13px; color: var(--muted, rgba(246,240,231,.72)); line-height: 1.5; }
	.sd-signin form { display: flex; gap: 8px; }
	.sd-signin input { flex: 1; }

	.sd-chat { display: flex; flex-direction: column; flex: 1; min-height: 0; }
	.sd-log { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
	.sd-bubble { max-width: 86%; padding: 9px 12px; border-radius: 13px; font-size: 13.5px; line-height: 1.45; white-space: pre-wrap; }
	.sd-bubble.you { align-self: flex-end; background: linear-gradient(135deg,#ffe7bf,#f2d2a2); color: #12100c; }
	.sd-bubble.ai { align-self: flex-start; background: rgba(255,255,255,.06); border: 1px solid var(--line, rgba(255,255,255,.12)); }
	.sd-thinking { color: var(--muted, rgba(246,240,231,.6)); animation: sd-pulse 1.2s ease-in-out infinite; }
	@keyframes sd-pulse { 0%,100% { opacity: .45; } 50% { opacity: .9; } }

	.sd-proposal { margin: 0 14px; border: 1px solid var(--gold-soft, rgba(242,210,162,.3)); border-radius: 13px; padding: 11px; background: rgba(242,210,162,.06); }
	.sd-proposal h4 { margin: 0 0 8px; font-size: 10.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--gold, #f2d2a2); }
	.sd-proposal .sd-field { font-size: 10.5px; color: var(--muted, rgba(246,240,231,.6)); margin-bottom: 2px; }
	.sd-proposal .sd-old { font-size: 13px; color: var(--rose, #eec7b7); text-decoration: line-through; opacity: .75; }
	.sd-proposal .sd-new { font-size: 13px; color: var(--gold-strong, #ffe7bf); }
	.sd-proposal .sd-acts { display: flex; gap: 7px; margin-top: 11px; }

	.sd-composer { display: flex; gap: 8px; padding: 12px 14px; border-top: 1px solid var(--line, rgba(255,255,255,.12)); }
	.sd-composer input { flex: 1; }

	.sd-root input[type=text], .sd-root input[type=password] {
		padding: 10px 12px; border-radius: 10px; font: inherit; font-size: 14px;
		background: rgba(255,255,255,.05); border: 1px solid var(--line, rgba(255,255,255,.16)); color: var(--text, #f6f0e7);
	}
	.sd-root input::placeholder { color: rgba(246,240,231,.4); }
	.sd-root button:not(.sd-icon):not(.sd-launch) {
		font: 600 14px/1 inherit; border: 0; border-radius: 10px; padding: 10px 14px; cursor: pointer;
		background: linear-gradient(135deg,#ffe7bf,#f2d2a2); color: #12100c;
	}
	.sd-root button.sd-ghost { background: transparent; border: 1px solid var(--line, rgba(255,255,255,.18)); color: var(--muted, rgba(246,240,231,.75)); }
	.sd-root button:disabled { opacity: .5; cursor: default; }
	.sd-err { color: var(--rose, #eec7b7); font-size: 12px; min-height: 16px; margin: 8px 0 0; }

	.sd-toast { position: fixed; right: 20px; bottom: 92px; z-index: 2147483001; background: linear-gradient(135deg,#ffe7bf,#f2d2a2); color:#12100c; font-weight:600; font-size:13px; padding: 9px 15px; border-radius: 999px; box-shadow: 0 14px 40px rgba(0,0,0,.5); opacity: 0; transition: opacity .2s; pointer-events: none; }
	.sd-toast.show { opacity: 1; }

	@media (max-width: 520px) {
		.sd-root { right: 12px; left: 12px; bottom: 12px; }
		.sd-panel { width: 100%; height: min(70vh, 560px); }
		.sd-launch { float: right; }
	}
</style>

<script>
	const root = document.getElementById("sd-root");
	if (root) {
		const $ = (id: string) => document.getElementById(id) as HTMLElement;
		const api = (path: string, opts?: RequestInit) =>
			fetch(path, { headers: { "content-type": "application/json" }, ...opts }).then((r) => r.json());
		const LOG_KEY = "sd_log", OPEN_KEY = "sd_open";
		let pending: any = null;

		// Friendly page name from the URL, e.g. "/vision-values" → "vision values".
		const path = location.pathname;
		const pageName = path === "/" ? "the homepage"
			: (document.title.split("|").pop() || path).replace(/[/-]/g, " ").trim() || path;
		$("sd-page").textContent = pageName;

		function setState(s: string) { root!.dataset.state = s; }
		function esc(s: any) { return String(s).replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" } as any)[c]); }

		function loadLog(): any[] { try { return JSON.parse(sessionStorage.getItem(LOG_KEY) || "[]"); } catch { return []; } }
		function saveLog(log: any[]) { sessionStorage.setItem(LOG_KEY, JSON.stringify(log.slice(-50))); }

		function renderLog() {
			const log = loadLog();
			$("sd-log").innerHTML = log.map((m) => `<div class="sd-bubble ${m.who}">${esc(m.text)}</div>`).join("");
			$("sd-log").scrollTop = $("sd-log").scrollHeight;
		}
		function addMsg(text: string, who: "you" | "ai") {
			const log = loadLog(); log.push({ text, who }); saveLog(log); renderLog();
		}

		function toast(msg: string) {
			let t = document.querySelector(".sd-toast") as HTMLElement;
			if (!t) { t = document.createElement("div"); t.className = "sd-toast"; document.body.appendChild(t); }
			t.textContent = msg; t.classList.add("show");
			setTimeout(() => t.classList.remove("show"), 1800);
		}

		function showChat() {
			$("sd-signin").hidden = true; $("sd-chat").hidden = false;
			$("sd-signout").hidden = false; $("sd-undo").hidden = false;
			sessionStorage.setItem(OPEN_KEY, "1"); // stay open as staff navigate
			renderLog();
			if (loadLog().length === 0) addMsg(`Hi! You're on ${pageName}. Tell me what to change — I'll show you the edit before anything goes live.`, "ai");
			setTimeout(() => $("sd-msg")?.focus(), 50);
		}
		function showSignin() {
			$("sd-signin").hidden = false; $("sd-chat").hidden = true;
			$("sd-signout").hidden = true; $("sd-undo").hidden = true;
			setTimeout(() => $("sd-pass")?.focus(), 50);
		}

		async function undoLast() {
			const res = await api("/api/studio/undo", { method: "POST" });
			if (res.ok) { toast("Reverted ✓"); addMsg("Reverted the last change. Reload to see it on the page.", "ai"); }
			else { addMsg(res.error || "Nothing to undo.", "ai"); }
		}

		function open() {
			setState("open"); sessionStorage.setItem(OPEN_KEY, "1");
			api("/api/studio/session").then((r) => { if (r.authed) showChat(); else { setState("signin"); showSignin(); } });
		}
		function close() { setState("closed"); sessionStorage.removeItem(OPEN_KEY); }

		function renderProposal(p: any) {
			pending = p;
			const slot = $("sd-proposal");
			if (!p.edits || !p.edits.length) { slot.innerHTML = ""; return; }
			slot.innerHTML = `<div class="sd-proposal"><h4>Proposed edit${p.edits.length > 1 ? "s" : ""}</h4>` +
				p.edits.map((e: any) => `<div class="sd-field">${esc(e.path)}</div><div class="sd-old">${esc(e.from ?? "")}</div><div class="sd-new">${esc(e.to)}</div>`).join("") +
				`<div class="sd-acts"><button id="sd-pub">Publish</button><button class="sd-ghost" id="sd-discard">Discard</button></div></div>`;
			$("sd-pub").onclick = publish;
			$("sd-discard").onclick = () => { pending = null; slot.innerHTML = ""; };
		}

		async function send(e: Event) {
			e.preventDefault();
			const input = $("sd-msg") as HTMLInputElement; const msg = input.value.trim();
			if (!msg) return;
			addMsg(msg, "you"); input.value = ""; $("sd-proposal").innerHTML = ""; pending = null;
			const btn = $("sd-send") as HTMLButtonElement; btn.disabled = true;
			const think = document.createElement("div");
			think.className = "sd-bubble ai sd-thinking"; think.textContent = "Thinking…";
			$("sd-log").appendChild(think); $("sd-log").scrollTop = $("sd-log").scrollHeight;
			try {
				const res = await api("/api/studio/chat", { method: "POST", body: JSON.stringify({ message: msg, path, page: pageName }) });
				think.remove();
				addMsg(res.reply || res.error || "…", "ai");
				renderProposal(res);
			} catch { think.remove(); addMsg("Something went wrong — try again.", "ai"); }
			finally { btn.disabled = false; input.focus(); }
		}

		async function publish() {
			if (!pending?.edits?.length) return;
			($("sd-pub") as HTMLButtonElement).disabled = true;
			const res = await api("/api/studio/apply", { method: "POST", body: JSON.stringify({ edits: pending.edits, summary: pending.reply }) });
			if (res.ok) {
				toast("Published ✓"); $("sd-proposal").innerHTML = ""; pending = null;
				addMsg("Done — it's live. Reload to see it on the page.", "ai");
			} else { addMsg("Couldn't publish: " + (res.error || "error"), "ai"); ($("sd-pub") as HTMLButtonElement).disabled = false; }
		}

		// Wire up
		$("sd-launch").addEventListener("click", open);
		$("sd-close").addEventListener("click", close);
		$("sd-undo").addEventListener("click", undoLast);
		$("sd-composer").addEventListener("submit", send);
		$("sd-signout").addEventListener("click", async () => {
			await api("/api/studio/session", { method: "DELETE" });
			sessionStorage.removeItem(LOG_KEY); sessionStorage.removeItem(OPEN_KEY);
			close(); toast("Signed out");
		});
		$("sd-signin-form").addEventListener("submit", async (e) => {
			e.preventDefault();
			const res = await api("/api/studio/session", { method: "POST", body: JSON.stringify({ passcode: ($("sd-pass") as HTMLInputElement).value }) });
			if (res.ok) { setState("open"); showChat(); } else { $("sd-signin-err").textContent = res.error || "Try again."; }
		});

		// Reveal logic: show launcher for signed-in staff; auto-open if ?edit or
		// the dock was left open on the previous page (persists across navigation).
		const wantEdit = /[?&#]edit\b/.test(location.search + location.hash);
		const wasOpen = sessionStorage.getItem(OPEN_KEY) === "1";
		api("/api/studio/session").then((r) => {
			if (r.authed) { setState(wasOpen ? "open" : "closed"); if (wasOpen) showChat(); }
			else if (wantEdit) { setState("signin"); showSignin(); }
			else { setState("hidden"); }
		});
	}
</script>
